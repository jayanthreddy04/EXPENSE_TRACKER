PORT=5001
MONGODB_URI=replace-with-your-mongodb-uri
JWT_SECRET=replace-with-a-long-random-secret
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional LangSmith tracing for receipt analysis.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=replace-with-your-langsmith-key
LANGSMITH_PROJECT=expense-tracker
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional fallback OCR provider. Only needed if you want Gemini as backup.
# GOOGLE_API_KEY=replace-with-your-google-ai-studio-key
# GEMINI_MODEL=gemini-2.5-flash
